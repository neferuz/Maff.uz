#!/usr/bin/expect -f
spawn ssh root@192.168.183.35
expect "assword:" { send "rJhj,rf2@\r" }
expect "Enter your choice:" { send "0\r" }
expect -re {.*#.*} { send "echo 'CLAUDE_API_KEY=\"$env(CLAUDE_API_KEY)\"' >> /var/www/new-maff-website/backend/.env\r" }
expect -re {.*#.*} { send "pm2 restart maff-backend\r" }
expect -re {.*#.*} { send "exit\r" }
