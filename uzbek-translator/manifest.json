{
  "manifest_version": 3,
  "name": "Uzbek Translator",
  "version": "1.0",
  "description": "Переводит сайты на узбекский язык через Claude AI",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Перевести на узбекский"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
