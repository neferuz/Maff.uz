#!/usr/bin/expect -f

set timeout 30
match_max 100000

spawn ssh root@192.168.183.35
expect {
    "yes/no" {
        send "yes\r"
        exp_continue
    }
    "assword:" {
        send "rJhj,rf2@\r"
    }
    timeout {
        puts "Connection to internal IP timed out"
        exit 1
    }
    eof {
        puts "Connection to internal IP failed"
        exit 1
    }
}

expect {
    "Enter your choice:" {
        send "0\r"
        exp_continue
    }
    -re {.*#.*} {
        send "cd /var/www/new-maff-website/backend\r"
    }
}

expect -re {.*#.*}
send "grep -q CLAUDE_API_KEY .env || echo 'CLAUDE_API_KEY=\"\"' >> .env\r"
expect -re {.*#.*}
send "pm2 restart maff-backend\r"
expect -re {.*#.*}
send "sleep 2\r"
expect -re {.*#.*}
send "pm2 logs maff-backend --lines 20 --nostream\r"
expect -re {.*#.*}
send "exit\r"
